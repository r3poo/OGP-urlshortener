{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/client/index.html --outdir=dist --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts",
    "serve": "bun run build && bun run start"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest"
  }
}
